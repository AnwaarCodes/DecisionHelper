{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "env": {
    "NPM_CONFIG_OPTIONAL": "false",
    "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
